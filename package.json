{
  "name": "science-tokyo-lms-discord-bot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Science Tokyo LMS assignments sync API and Discord reminder bot",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "register-commands": "tsx src/register-commands.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "discord.js": "^14.26.5",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^24.10.0",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2"
  },
  "overrides": {
    "undici": "6.27.0"
  }
}
