{
  "name": "science-tokyo-lms-discord-bot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Cloudflare Worker that syncs Science Tokyo LMS assignments and sends Discord reminders",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "wrangler dev --test-scheduled",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "register-commands": "tsx scripts/register-commands.ts",
    "db:migrate:local": "wrangler d1 migrations apply science-tokyo-lms-discord-bot --local",
    "db:migrate:remote": "wrangler d1 migrations apply science-tokyo-lms-discord-bot --remote",
    "cf-typegen": "wrangler types"
  },
  "dependencies": {
    "discord-interactions": "^4.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.18.4",
    "@cloudflare/workers-types": "^5.20260714.1",
    "@types/node": "^24.10.0",
    "dotenv": "^17.4.2",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10",
    "wrangler": "^4.110.0"
  }
}
